PROCESS_TYPE=server
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
PG_POOL_SIZE=10
# Comma-separated browser origins allowed in production. Development also allows private LAN origins.
CORS_ORIGIN=http://localhost:5173
# Optional override; the server derives frontend/dist from its module location by default.
FRONTEND_DIST_DIR=

DATABASE_URL=postgres://user:password@localhost:5432/chalkboard
REDIS_URL=redis://localhost:6379

# Google Identity Services Web client ID
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# The first account matching this email is promoted to Super Admin after Google sign-in.
SUPER_ADMIN_EMAIL=you@example.com
# Use a random value with at least 32 characters.
AUTH_SESSION_SECRET=replace-with-a-long-random-session-secret

LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Permanently close an open room after 24 hours without a join or canvas update.
ROOM_INACTIVITY_MS=86400000
# How often the worker scans for inactive rooms.
ROOM_CLEANUP_REPEAT_MS=3600000
