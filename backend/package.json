{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "PROCESS_TYPE=server tsx watch --tsconfig tsconfig.json src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "dev:worker": "PROCESS_TYPE=worker tsx watch --tsconfig tsconfig.json src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.64.1",
    "drizzle-orm": "^0.45.1",
    "google-auth-library": "^10.5.0",
    "hono": "^4.10.7",
    "livekit-server-sdk": "^2.14.0",
    "postgres": "^3.4.7",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "winston": "^3.18.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.9",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^7.0.2"
  }
}
